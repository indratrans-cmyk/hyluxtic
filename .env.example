# ===== OTAK AI (pilih SATU — semuanya GRATIS) =====
# Prioritas: GROQ_API_KEY > GEMINI_API_KEY > OLLAMA_URL.
# Tanpa satupun, UNIT-01 tetap jalan dalam mode rule-based (perintah saja).

# Groq free tier — daftar gratis tanpa kartu di https://console.groq.com
# ~14.400 request/hari gratis, model Llama 3.3 70B (pintar & sangat cepat). REKOMENDASI.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini free tier — https://aistudio.google.com/apikey (gratis, tanpa kartu)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Ollama lokal — 100% offline, tanpa API key sama sekali.
# Install: curl -fsSL https://ollama.com/install.sh | sh  lalu: ollama pull llama3.2
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ===== PEMBAYARAN SOLANA (non-custodial) =====
# Alamat wallet penerima pembayaran (wallet Anda). Kosong = top-up dinonaktifkan.
TREASURY_WALLET=
# RPC publik gratis (default). Bisa diganti Helius/QuickNode free tier untuk keandalan.
# SOLANA_RPC=https://api.mainnet-beta.solana.com

# ===== TOKEN =====
# Isi setelah dapat contract address dari pump.fun:
TOKEN_CA=
PUMP_URL=https://pump.fun
